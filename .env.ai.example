AGENT_USE_MOCK_LLM=true
AGENT_MODE=plan_first

AGENT_DEFAULT_MODEL=openai/gpt-4o-mini
AGENT_CHEAP_MODEL=openai/gpt-4o-mini
AGENT_STRONG_MODEL=openai/gpt-4.1

AGENT_LITELLM_BASE_URL=http://litellm:4000/v1
AGENT_LITELLM_API_KEY=change_me
LITELLM_MASTER_KEY=change_me

OPENAI_API_KEY=change_me
OPENAI_PROJECT_ID=change_me

CONTROL_API_HOST=0.0.0.0
CONTROL_API_PORT=8000
CONTROL_API_LOG_LEVEL=INFO
CONTROL_API_LOG_DIR=/app/logs
CONTROL_API_DATA_DIR=/app/data/ai_control

AGENT_RUN_TIMEOUT_SECONDS=180
AGENT_MAX_PARALLEL_RUNS=1
AGENT_GLOBAL_DAILY_BUDGET_USD=5.0
AGENT_GLOBAL_PER_RUN_BUDGET_USD=0.5
AGENT_ALLOW_MOCK_FALLBACK=true
AGENT_KILL_SWITCH=false

CREWAI_DISABLE_TELEMETRY=true
