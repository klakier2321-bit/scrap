AGENT_USE_MOCK_LLM=true
AGENT_MODE=plan_first
AGENT_CHEAP_MODEL=openai/gpt-5-mini
AGENT_STRONG_MODEL=openai/gpt-5.4

AGENT_LITELLM_BASE_URL=http://litellm:4000/v1
AGENT_LITELLM_API_KEY=change_me

CONTROL_API_HOST=0.0.0.0
CONTROL_API_PORT=8000
CONTROL_API_LOG_LEVEL=INFO
CONTROL_API_LOG_DIR=/app/logs
CONTROL_API_DATA_DIR=/app/data/ai_control

AGENT_RUN_TIMEOUT_SECONDS=180
AGENT_MAX_PARALLEL_RUNS=3
AGENT_CODING_TASK_TIMEOUT_SECONDS=180
AGENT_GLOBAL_DAILY_BUDGET_USD=5.0
AGENT_GLOBAL_PER_RUN_BUDGET_USD=0.5
AGENT_ALLOW_MOCK_FALLBACK=true
AGENT_KILL_SWITCH=false
AGENT_AUTOPILOT_ENABLED=false
AGENT_AUTOPILOT_POLL_INTERVAL_SECONDS=300
AGENT_AUTOPILOT_MAX_CYCLES=0
AGENT_AUTOPILOT_CONFIG=/app/ai_agents/config/autopilot.yaml
CREWAI_DISABLE_TELEMETRY=true
CREWAI_TRACING_ENABLED=false
AGENT_TRACING_ENABLED=true
AGENT_OTLP_HTTP_ENDPOINT=http://tempo:4318/v1/traces

FREQTRADE_API_BASE_URL=http://freqtrade:8080/api/v1
FREQTRADE_API_USERNAME=freqtrader
FREQTRADE_API_PASSWORD=change_me
FREQTRADE_API_TIMEOUT_SECONDS=5
DRY_RUN_SNAPSHOT_STALE_SECONDS=180
