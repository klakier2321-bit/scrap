  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "sum(increase(crypto_ai_estimated_cost_usd_total[24h]))", "refId": "A" }],
      "title": "Estimated Cost 24h",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "sum(increase(crypto_ai_total_tokens_total[24h]))", "refId": "A" }],
      "title": "Total Tokens 24h",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "sum(increase(crypto_ai_prompt_tokens_total[24h]))", "refId": "A" }],
      "title": "Prompt Tokens 24h",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (agent_name) (increase(crypto_ai_estimated_cost_usd_total[24h]))",
          "legendFormat": "{{agent_name}}",
          "refId": "A"
        }
      ],
      "title": "Cost by Agent (24h)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (agent_name, model) (increase(crypto_ai_total_tokens_total[24h]))",
          "legendFormat": "{{agent_name}} / {{model}}",
          "refId": "A"
        }
      ],
      "title": "Tokens by Agent and Model (24h)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["crypto-system", "costs", "tokens"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
