  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 3, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "sum(crypto_ai_bot_running)", "refId": "A" }],
      "title": "Uruchomione boty",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 3, "x": 3, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "sum(increase(crypto_ai_estimated_cost_usd_total[24h]))", "refId": "A" }],
      "title": "Koszt AI 24h",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 3, "x": 6, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "sum(increase(crypto_ai_agent_runs_total{status=\"completed\"}[24h]))", "refId": "A" }],
      "title": "Runy AI 24h",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 3, "x": 9, "y": 0 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "max(crypto_strategy_latest_profit_pct)", "refId": "A" }],
      "title": "Ostatni profit strategii",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 3, "x": 0, "y": 8 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "max(crypto_strategy_latest_drawdown_pct)", "refId": "A" }],
      "title": "Ostatni drawdown strategii",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 3, "x": 3, "y": 8 },
      "id": 8,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "max(crypto_strategy_latest_total_trades)", "refId": "A" }],
      "title": "Trade'y ostatniego raportu",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            { "options": { "0": { "text": "Nie" }, "1": { "text": "Tak" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 3, "x": 6, "y": 8 },
      "id": 9,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "expr": "max(crypto_strategy_stage_candidate)", "refId": "A" }],
      "title": "Status oceny strategii",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 16 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (bot_id) (crypto_ai_bot_running)",
          "legendFormat": "{{bot_id}}",
          "refId": "A"
        }
      ],
      "title": "Stan botów runtime",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 26 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (agent_name) (increase(crypto_ai_agent_runs_total[24h]))",
          "legendFormat": "{{agent_name}}",
          "refId": "A"
        }
      ],
      "title": "Aktywność agentów 24h",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 36 },
      "id": 10,
      "targets": [
        {
          "expr": "max by (strategy_name) (crypto_strategy_latest_profit_pct)",
          "legendFormat": "{{strategy_name}}",
          "refId": "A"
        },
        {
          "expr": "max by (strategy_name) (crypto_strategy_latest_drawdown_pct)",
          "legendFormat": "{{strategy_name}} drawdown",
          "refId": "B"
        }
      ],
      "title": "Ostatni wynik strategii",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 46 },
      "id": 11,
      "targets": [
        {
          "expr": "max by (strategy_name, source_run_id, evaluation_status) (crypto_strategy_report_profit_pct)",
          "legendFormat": "{{strategy_name}} {{source_run_id}} profit",
          "refId": "A"
        },
        {
          "expr": "max by (strategy_name, source_run_id, evaluation_status) (crypto_strategy_report_drawdown_pct)",
          "legendFormat": "{{strategy_name}} {{source_run_id}} drawdown",
          "refId": "B"
        }
      ],
      "title": "Historia raportow strategii",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["crypto-system", "trading", "ai"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Trading i AI",
  "uid": "crypto-trading-ai",
  "version": 2
}
